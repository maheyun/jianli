    "    ax.bar(x + width / 2, slow_display['total_volume'], width,\n",
    "           label='累计销量', color='#64B5F6')\n",
    "    ax.set_xticks(x)\n",
    "    ax.set_xticklabels(slow_display['product_name'], rotation=30, ha='right', fontsize=8)\n",
